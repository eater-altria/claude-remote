# Copy to relay/.env — auto-loaded on start (real shell env still wins over .env).

# RELAY_PORT=8080
# RELAY_HOST=0.0.0.0
RELAY_TOKEN=change-me-shared-secret   # secret every local server must present to register
# RELAY_PUBLIC_URL=https://relay.example.com   # public address; when set, prints a pairing QR each time a server connects
