# Copy to server/.env — auto-loaded on start (real shell env still wins over .env).
# Real env vars override these; values here override config.json.

# --- Core ---
# CLAUDE_REMOTE_PORT=8787
# CLAUDE_REMOTE_HOST=0.0.0.0
# CLAUDE_REMOTE_TOKEN=                 # app access token (auto-generated if unset)
# CLAUDE_REMOTE_CLAUDE_PATH=           # path to the `claude` binary (auto-detected)
# CLAUDE_REMOTE_DATA_DIR=~/.claude-remote
# CLAUDE_REMOTE_MAX_LIVE=12

# --- Cloud relay (optional; off by default) ---
# CLAUDE_REMOTE_RELAY_ENABLED=1
# CLAUDE_REMOTE_RELAY_URL=https://relay.example.com   # https; ws/wss derived
# CLAUDE_REMOTE_RELAY_TOKEN=                           # must equal the relay's RELAY_TOKEN
# CLAUDE_REMOTE_RELAY_SERVER_ID=home-mac              # app address: <relay>/s/<serverId>; auto-generated if unset
# CLAUDE_REMOTE_RELAY_NAME=Home Mac
